---

<!-- Label linked to #theme-toggle checkbox in BaseLayout.
     Toggling theme works without JavaScript — CSS :has() handles colors and icons. -->
<label
  for="theme-toggle"
  class="theme-toggle-btn relative cursor-pointer rounded-full p-2 text-foreground transition-colors hover:bg-foreground/10 focus-within:outline-none"
  aria-label="Toggle theme"
>
  <!-- Sun icon (shown in dark mode — click to go light) -->
  <svg
    class="sun-icon h-5 w-5"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <!-- Moon icon (shown in light mode — click to go dark) -->
  <svg
    class="moon-icon h-5 w-5"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</label>
