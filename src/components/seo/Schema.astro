---
import { siteConfig } from "@/config/site";

interface Props {
  type: "WebSite" | "BlogPosting" | "BreadcrumbList";
  data: {
    title?: string;
    description?: string;
    image?: string;
    pubDate?: Date;
    modDate?: Date;
    author?: string;
    url?: string;
    breadcrumbs?: Array<{ name: string; url: string }>;
  };
}

const { type, data } = Astro.props;

let schema = {};

if (type === "WebSite") {
  schema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.name,
    url: siteConfig.url,
    description: siteConfig.description,
    author: {
      "@type": "Person",
      name: siteConfig.author,
    },
    sameAs: [siteConfig.socialLinks.twitter],
  };
} else if (type === "BlogPosting") {
  schema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    image: data.image,
    datePublished: data.pubDate,
    dateModified: data.modDate ?? data.pubDate,
    author: {
      "@type": "Person",
      name: data.author,
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.name,
      logo: {
        "@type": "ImageObject",
        url: new URL("/favicon.svg", siteConfig.url).toString(),
      },
    },
  };
} else if (type === "BreadcrumbList" && data.breadcrumbs?.length) {
  schema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: data.breadcrumbs.map((crumb, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: crumb.name,
      item: crumb.url,
    })),
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
